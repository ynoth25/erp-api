# Aurora DSQL connection (IAM auth — tokens generated at runtime, no static password)
DSQL_HOST=your-cluster.dsql.ap-northeast-1.on.aws
DSQL_USER=admin
DSQL_DATABASE=postgres
DSQL_REGION=ap-northeast-1
DSQL_PORT=5432

# Security: API keys and allowed origins
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=your-api-key-here
ALLOWED_ORIGINS=https://your-frontend.com,http://localhost:3001

# Facebook Lead Ads webhook
FB_VERIFY_TOKEN=any-secret-string-you-choose
FB_APP_SECRET=your-facebook-app-secret
FB_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token

# Cognito (from SAM stack outputs after deploy)
COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-northeast-1
