# Database (PostgreSQL). For local SQLite, change provider in prisma/schema.prisma to "sqlite" and url to "file:./dev.db"
DATABASE_URL="postgresql://user:password@localhost:5432/erp?schema=public"

# Aurora DSQL (optional – IAM auth; used when connecting to Aurora DSQL in Lambda or local with AWS creds)
# Host from Aurora DSQL cluster (e.g. mycluster.dsql.us-east-1.on.aws). No password – connector uses IAM tokens.
DSQL_HOST=
DSQL_USER=admin
DSQL_DATABASE=postgres
DSQL_REGION=
DSQL_PORT=5432
