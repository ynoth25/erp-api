// ERP API — Multi-tenant DTR platform
// https://pris.ly/d/prisma-schema
//
// Architecture: Company is the tenant. Users register → join a Company as a
// CompanyMember → clock in/out → Attendance + ClockEvent records are created.
// Biometric devices authenticate with their own API key and post clock events
// directly via webhook.
//
// Aurora DSQL compatibility:
//   - relationMode = "prisma" (DSQL has no foreign keys)
//   - UUID IDs via gen_random_uuid() @db.Uuid (no sequences/serial)
//   - No Prisma @relation enforcement → app-level joins
//   - Indexes created via DSQL migration tool (CREATE INDEX ASYNC)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ═══════════════════════════════════════════════════════════
// IDENTITY
// ═══════════════════════════════════════════════════════════

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cognitoSub   String
  email        String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  isAdmin      Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("app_user")
}

// ═══════════════════════════════════════════════════════════
// MULTI-TENANCY
// ═══════════════════════════════════════════════════════════

model Company {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  code         String
  address      String?
  timezone     String   @default("Asia/Manila")
  logoUrl      String?
  settings     String?
  isActive     Boolean  @default(true)
  ownerId      String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("company")
}

model CompanyMember {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @db.Uuid
  userId       String   @db.Uuid
  role         String   @default("MEMBER")
  memberType   String   @default("EMPLOYEE")
  employeeId   String?
  department   String?
  position     String?
  status       String   @default("ACTIVE")
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("company_member")
}

model CompanyInvite {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String    @db.Uuid
  email        String?
  role         String    @default("MEMBER")
  memberType   String    @default("EMPLOYEE")
  token        String
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedBy   String?   @db.Uuid
  createdAt    DateTime  @default(now())

  @@map("company_invite")
}

// ═══════════════════════════════════════════════════════════
// BIOMETRIC DEVICES
// ═══════════════════════════════════════════════════════════

model BiometricDevice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String    @db.Uuid
  name          String
  serialNumber  String?
  deviceType    String
  location      String?
  apiKey        String
  isActive      Boolean   @default(true)
  lastHeartbeat DateTime?
  metadata      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("biometric_device")
}

// ═══════════════════════════════════════════════════════════
// ATTENDANCE & TIME TRACKING
// ═══════════════════════════════════════════════════════════

model Attendance {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String    @db.Uuid
  memberId      String    @db.Uuid
  date          DateTime
  status        String    @default("PRESENT")
  firstClockIn  DateTime?
  lastClockOut  DateTime?
  totalMinutes  Int?
  overtimeMin   Int?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("attendance")
}

model ClockEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String    @db.Uuid
  memberId      String    @db.Uuid
  attendanceId  String?   @db.Uuid
  eventType     String
  timestamp     DateTime
  source        String
  deviceId      String?   @db.Uuid
  locationLat   Float?
  locationLng   Float?
  photoUrl      String?
  remarks       String?
  createdAt     DateTime  @default(now())

  @@map("clock_event")
}

// ═══════════════════════════════════════════════════════════
// RECORDS REQUESTS (School document request tracking)
// ═══════════════════════════════════════════════════════════

model RecordsRequest {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String    @db.Uuid
  lrn             String?
  studentName     String
  gender          String?
  lastSchoolYear  String?
  gradeSection    String?
  major           String?
  adviser         String?
  contactNo       String?
  requestorName   String?
  requestTypes    String
  otherRequest    String?
  status          String    @default("PENDING")
  remarks         String?
  source          String    @default("WEB")
  processedBy     String?   @db.Uuid
  submittedAt     DateTime  @default(now())
  processedAt     DateTime?
  releasedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("records_request")
}
