  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Sign Up",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"MyPass123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+639171234567\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "2. Confirm Sign Up (verify email)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "confirm"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "3. Resend Verification Code",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/resend-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "resend-code"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "4. Login (get tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set(\"bearerToken\", json.accessToken);",
                  "  console.log(\"bearerToken set from login response\");",
                  "}",
                  "if (json.refreshToken) {",
                  "  pm.collectionVariables.set(\"refreshTokenValue\", json.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"MyPass123\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "5. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set(\"bearerToken\", json.accessToken);",
                  "  console.log(\"bearerToken refreshed\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshTokenValue}}\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "6. Forgot Password",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "7. Confirm Forgot Password (reset)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/confirm-forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "confirm-forgot-password"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"NewPass456\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "8. Change Password (requires token)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "change-password"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"previousPassword\": \"MyPass123\",\n  \"newPassword\": \"NewPass456\"\n}"
            }
          }
        }
      ]
    },
